generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────────────
model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  passwordHash    String
  avatar          String?
  isVerified      Boolean  @default(false)
  isAdmin         Boolean  @default(false)
  isBanned        Boolean  @default(false)
  theme           String   @default("light")
  phone           String?
  phoneVerified   Boolean  @default(false)
  documentVerified Boolean @default(false)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  emailVerifyToken String?
  emailVerifiedAt  DateTime?
  resetToken       String?
  resetTokenExpires DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings        Listing[]
  reviewsGiven    Review[]       @relation("ReviewAuthor")
  reviewsReceived Review[]       @relation("ReviewTarget")
  favorites       Favorite[]
  conversations1  Conversation[] @relation("UserA")
  conversations2  Conversation[] @relation("UserB")
  messages        Message[]
  reportsGiven    Report[]       @relation("ReportReporter")
  subscriptions   Subscription[]
  refreshTokens   RefreshToken[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ── Listings ──────────────────────────────────────────────────────────────
model Listing {
  id            String   @id @default(uuid())
  title         String
  description   String
  price         Float
  category      String
  brand         String?
  model         String?
  condition     String   // 'new' | 'used'
  status        String   @default("active") // draft | active | paused | sold | expired | moderation
  city          String
  state         String
  lat           Float?
  lng           Float?
  isBoosted     Boolean  @default(false)
  boostExpiresAt DateTime?
  viewCount     Int      @default(0)
  favoriteCount Int      @default(0)
  sellerId      String
  seller        User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images        ListingImage[]
  favorites     Favorite[]
  conversations Conversation[]
  boosts        Boost[]
  reports       Report[] @relation("ReportListing")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, isBoosted])
  @@index([category, status])
  @@index([sellerId])
}

model ListingImage {
  id        String  @id @default(uuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  thumb     String
  order     Int     @default(0)
}

// ── Chat ─────────────────────────────────────────────────────────────────
model Conversation {
  id        String    @id @default(uuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userAId   String
  userA     User      @relation("UserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User      @relation("UserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([listingId, userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Message {
  id              String       @id @default(uuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content         String
  isBlocked       Boolean      @default(false)
  blockReason     String?      // 'phone' | 'email' | 'url' | 'social'
  isRead          Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@index([conversationId])
}

// ── Reviews ───────────────────────────────────────────────────────────────
model Review {
  id        String  @id @default(uuid())
  authorId  String
  author    User    @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetId  String
  target    User    @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  rating    Int     // 1-5
  comment   String
  createdAt DateTime @default(now())

  @@unique([authorId, targetId])
}

// ── Favorites ─────────────────────────────────────────────────────────────
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

// ── Monetization ──────────────────────────────────────────────────────────
model Subscription {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  status      String   @default("active") // active | cancelled | expired
  billing     String   // monthly | annual
  price       Float
  startsAt    DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model Boost {
  id          String   @id @default(uuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  plan        String   // 7d | 15d | 30d
  price       Float
  status      String   @default("active")
  startsAt    DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

// ── Ads / Banners ─────────────────────────────────────────────────────────
model AdSlot {
  id         String    @id @default(uuid())
  name       String
  position   String    // top | sidebar | between-listings | footer | event-top
  isPremium  Boolean   @default(false)
  maxBanners Int       @default(5)
  banners    AdBanner[]
}

model AdBanner {
  id           String   @id @default(uuid())
  slotId       String
  slot         AdSlot   @relation(fields: [slotId], references: [id])
  advertiser   String
  imageUrl     String
  linkUrl      String
  weight       Int      @default(1)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  status       String   @default("active") // active | paused | expired
  startsAt     DateTime
  endsAt       DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slotId, status])
}

// ── Reports ───────────────────────────────────────────────────────────────
model Report {
  id          String   @id @default(uuid())
  reporterId  String
  reporter    User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  String   // listing | user
  targetId    String
  listingId   String?
  listing     Listing? @relation("ReportListing", fields: [listingId], references: [id], onDelete: SetNull)
  reason      String
  details     String?
  status      String   @default("pending") // pending | reviewed | actioned | dismissed
  actionTaken String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([targetType, targetId])
}
