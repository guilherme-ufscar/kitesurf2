# ── Porta única exposta ao host ──────────────────────────────────────────────
APP_PORT=8080

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://kite360.exemplo.com
JWT_SECRET=troque-para-um-segredo-forte-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Banco de Dados ────────────────────────────────────────────────────────────
POSTGRES_USER=kite360
POSTGRES_PASSWORD=troque-a-senha
POSTGRES_DB=kite360
DATABASE_URL=postgres://kite360:troque-a-senha@db:5432/kite360

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── E-mail (Resend + Fallback SMTP) ──────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=no-reply@kite360.exemplo.com
EMAIL_FALLBACK_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Uploads locais ────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=15

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Mapas (open source) ───────────────────────────────────────────────────────
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ── Feature flags ─────────────────────────────────────────────────────────────
EVENT_MODULE_ENABLED=true
